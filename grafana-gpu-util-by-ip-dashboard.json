          "editorMode": "code",
          "expr": "count(count by (node, gpu) (DCGM_FI_DEV_GPU_UTIL{instance=~\"${ip:regex}:.*\", node=~\"${node:regex}\", gpu=~\"${gpu:regex}\"}))",
