      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "editorMode": "code",
          "expr": "avg(DCGM_FI_DEV_GPU_UTIL{instance=~\"${ip:regex}:.*\", node=~\"${node:regex}\", gpu=~\"${gpu:regex}\"})",
          "instant": true,
          "legendFormat": "当前平均利用率",
          "range": false,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "avg(avg_over_time(DCGM_FI_DEV_GPU_UTIL{instance=~\"${ip:regex}:.*\", node=~\"${node:regex}\", gpu=~\"${gpu:regex}\"}[$__range]))",
          "instant": true,
          "legendFormat": "时间范围平均利用率",
          "range": false,
          "refId": "B"
