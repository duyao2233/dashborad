      "targets": [
        {
          "editorMode": "code",
          "expr": "avg by (node) (DCGM_FI_DEV_GPU_UTIL{instance=~\"${ip:regex}:.*\", node=~\"${node:regex}\", gpu=~\"${gpu:regex}\"})",
