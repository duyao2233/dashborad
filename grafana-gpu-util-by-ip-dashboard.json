          "legendFormat": "{{node}}",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "当前各节点平均 GPU 利用率",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "总表：每个节点每张 GPU 的当前值 + 历史统计（Current/Min/Max/Mean），值班一眼可见。",
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "editorMode": "code",
          "expr": "DCGM_FI_DEV_GPU_UTIL{instance=~\"${ip:regex}:.*\", node=~\"${node:regex}\", gpu=~\"${gpu:regex}\"}",
          "instant": false,
          "legendFormat": "{{node}} | {{instance}} | GPU{{gpu}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "每节点每 GPU 总表（当前 + 历史统计）",
      "transformations": [
        {
          "id": "reduce",
          "options": {
            "labelsToFields": true,
            "reducers": [
              "lastNotNull",
              "min",
              "max",
              "mean"
            ]
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "Value #A (lastNotNull)": 3,
              "Value #A (max)": 5,
              "Value #A (mean)": 6,
              "Value #A (min)": 4,
              "gpu": 2,
              "instance": 1,
              "node": 0
            },
            "renameByName": {
              "Value #A (lastNotNull)": "Current(%)",
              "Value #A (max)": "Max(%)",
              "Value #A (mean)": "Mean(%)",
              "Value #A (min)": "Min(%)",
              "gpu": "GPU",
              "instance": "IP:Port",
              "node": "Node"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "同一视图查看每张卡的当前与历史走势，值班时可快速定位持续高负载 GPU。",
