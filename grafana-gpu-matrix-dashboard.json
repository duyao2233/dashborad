{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for GPU metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.4.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "text",
      "name": "Text",
      "version": ""
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "gridPos": {
        "h": 1,
        "w": 3,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "options": {
        "content": "<div style=\"font-size:15px;text-align:left;font-weight:600;line-height:22px;padding-left:6px;\">Node</div>",
        "mode": "html"
      },
      "title": "",
      "transparent": true,
      "type": "text"
    },
    {
      "gridPos": {
        "h": 1,
        "w": 2,
        "x": 3,
        "y": 0
      },
      "id": 101,
      "maxPerRow": 8,
      "options": {
        "content": "<div style=\"font-size:13px;text-align:center;font-weight:600;line-height:22px;\">$gpu卡</div>",
        "mode": "html"
      },
      "repeat": "gpu",
      "title": "",
      "transparent": true,
      "type": "text"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "panels": [],
      "repeat": "node",
      "title": "",
      "type": "row"
    },
    {
      "gridPos": {
        "h": 3,
        "w": 3,
        "x": 0,
        "y": 2
      },
      "id": 102,
      "options": {
        "content": "<div style=\"font-size:13px;text-align:left;font-weight:500;line-height:56px;padding-left:8px;\">$node</div>",
        "mode": "html"
      },
      "title": "",
      "transparent": true,
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "每个单元格显示当前利用率（中间数字）+ 当前 dashboard 时间范围历史趋势（背景折线）。",
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "#F2CC0C",
            "mode": "fixed"
          },
          "decimals": 1,
          "max": 100,
          "min": 0,
          "noValue": "N/A",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#299c46",
                "value": null
              },
              {
                "color": "#EAB839",
                "value": 50
              },
              {
                "color": "#d44a3a",
                "value": 85
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 3,
        "w": 2,
        "x": 3,
        "y": 2
      },
      "id": 2,
      "maxPerRow": 8,
      "options": {
        "colorMode": "none",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "pluginVersion": "10.4.0",
      "repeat": "gpu",
      "targets": [
        {
          "editorMode": "code",
          "expr": "DCGM_FI_DEV_GPU_UTIL{node=\"$node\", gpu=\"$gpu\"}",
          "instant": false,
          "legendFormat": "GPU{{gpu}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "",
      "transparent": false,
      "type": "stat"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "gpu",
    "dcgm",
    "matrix",
    "single-table-like",
    "stat-sparkline"
  ],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(DCGM_FI_DEV_GPU_UTIL, node)",
        "hide": 2,
        "includeAll": true,
        "label": "Node",
        "multi": true,
        "name": "node",
        "options": [],
        "query": {
          "query": "label_values(DCGM_FI_DEV_GPU_UTIL, node)",
          "refId": "PrometheusVariableQueryEditor-Node"
        },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(DCGM_FI_DEV_GPU_UTIL{node=~\"${node:regex}\"}, gpu)",
        "hide": 2,
        "includeAll": true,
        "label": "GPU",
        "multi": true,
        "name": "gpu",
        "options": [],
        "query": {
          "query": "label_values(DCGM_FI_DEV_GPU_UTIL{node=~\"${node:regex}\"}, gpu)",
          "refId": "PrometheusVariableQueryEditor-GPU"
        },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 3,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m"
    ]
  },
  "timezone": "browser",
  "title": "GPU Util Matrix (Value + Sparkline Style)",
  "uid": "ai-gpu-util-matrix",
  "version": 7,
  "weekStart": ""
}
