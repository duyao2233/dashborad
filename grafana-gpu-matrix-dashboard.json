{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for GPU metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.4.0"
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "单个大表格：行=Node，列=1卡~8卡（对应 GPU0~GPU7）。每个单元格中间显示当前利用率，背景 sparkline 为当前时间范围历史利用率。",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "center",
            "cellOptions": {
              "drawStyle": "line",
              "fillOpacity": 30,
              "gradientMode": "opacity",
              "hideValue": false,
              "lineInterpolation": "linear",
              "lineStyle": {
                "dash": [
                  0,
                  0
                ],
                "fill": "solid"
              },
              "lineWidth": 2,
              "pointSize": 2,
              "showPoints": "never",
              "spanNulls": true,
              "type": "sparkline"
            },
            "inspect": false
          },
          "decimals": 1,
          "max": 100,
          "min": 0,
          "noValue": "-",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Node"
            },
            "properties": [
              {
                "id": "custom.align",
                "value": "left"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "auto"
                }
              },
              {
                "id": "unit",
                "value": "none"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 22,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "cellHeight": "lg",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "frozenColumns": 1,
        "showHeader": true,
        "sortBy": [
          {
            "desc": false,
            "displayName": "Node"
          }
        ]
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "editorMode": "code",
          "expr": "avg by (node) (DCGM_FI_DEV_GPU_UTIL{gpu=\"0\"})",
          "instant": false,
          "legendFormat": "1卡",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "avg by (node) (DCGM_FI_DEV_GPU_UTIL{gpu=\"1\"})",
          "instant": false,
          "legendFormat": "2卡",
          "range": true,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "avg by (node) (DCGM_FI_DEV_GPU_UTIL{gpu=\"2\"})",
          "instant": false,
          "legendFormat": "3卡",
          "range": true,
          "refId": "C"
        },
        {
          "editorMode": "code",
          "expr": "avg by (node) (DCGM_FI_DEV_GPU_UTIL{gpu=\"3\"})",
          "instant": false,
          "legendFormat": "4卡",
          "range": true,
          "refId": "D"
        },
        {
          "editorMode": "code",
          "expr": "avg by (node) (DCGM_FI_DEV_GPU_UTIL{gpu=\"4\"})",
          "instant": false,
          "legendFormat": "5卡",
          "range": true,
          "refId": "E"
        },
        {
          "editorMode": "code",
          "expr": "avg by (node) (DCGM_FI_DEV_GPU_UTIL{gpu=\"5\"})",
          "instant": false,
          "legendFormat": "6卡",
          "range": true,
          "refId": "F"
        },
        {
          "editorMode": "code",
          "expr": "avg by (node) (DCGM_FI_DEV_GPU_UTIL{gpu=\"6\"})",
          "instant": false,
          "legendFormat": "7卡",
          "range": true,
          "refId": "G"
        },
        {
          "editorMode": "code",
          "expr": "avg by (node) (DCGM_FI_DEV_GPU_UTIL{gpu=\"7\"})",
          "instant": false,
          "legendFormat": "8卡",
          "range": true,
          "refId": "H"
        }
      ],
      "title": "GPU 利用率大表（Node x GPU：当前值 + 历史折线）",
      "transformations": [
        {
          "id": "timeSeriesTable",
          "options": {}
        },
        {
          "id": "joinByField",
          "options": {
            "byField": "node",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "1卡": 1,
              "2卡": 2,
              "3卡": 3,
              "4卡": 4,
              "5卡": 5,
              "6卡": 6,
              "7卡": 7,
              "8卡": 8,
              "Node": 0
            },
            "renameByName": {
              "A": "1卡",
              "B": "2卡",
              "C": "3卡",
              "D": "4卡",
              "E": "5卡",
              "F": "6卡",
              "G": "7卡",
              "H": "8卡",
              "Trend #A": "1卡",
              "Trend #B": "2卡",
              "Trend #C": "3卡",
              "Trend #D": "4卡",
              "Trend #E": "5卡",
              "Trend #F": "6卡",
              "Trend #G": "7卡",
              "Trend #H": "8卡",
              "Value #A": "1卡",
              "Value #B": "2卡",
              "Value #C": "3卡",
              "Value #D": "4卡",
              "Value #E": "5卡",
              "Value #F": "6卡",
              "Value #G": "7卡",
              "Value #H": "8卡",
              "node": "Node"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "gpu",
    "dcgm",
    "matrix",
    "single-table",
    "sparkline"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m"
    ]
  },
  "timezone": "browser",
  "title": "GPU Util Matrix (Single Big Table)",
  "uid": "ai-gpu-util-matrix",
  "version": 4,
  "weekStart": ""
}
